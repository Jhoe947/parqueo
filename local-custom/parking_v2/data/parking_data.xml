<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <!-- noupdate="1": si ya existen estos registros no los toca al actualizar -->
    <data noupdate="1">
    <record id="seq_parking_ticket" model="ir.sequence">
        <field name="name">Secuencia Ticket Parqueo</field>
        <field name="code">parking2.ticket</field>
        <field name="prefix">TKT-%(year)s-</field>
        <field name="padding">5</field>
        <field name="number_next">1</field>
        <field name="number_increment">1</field>
    </record>

    <record id="rate_hourly_car" model="parking2.rate">
        <field name="name">Por Hora - Automovil</field>
        <field name="rate_type">hourly</field>
        <field name="price">5.00</field>
        <field name="vehicle_type">car</field>
        <field name="min_minutes">60</field>
        <field name="grace_minutes">10</field>
    </record>
    <record id="rate_hourly_moto" model="parking2.rate">
        <field name="name">Por Hora - Motocicleta</field>
        <field name="rate_type">hourly</field>
        <field name="price">3.00</field>
        <field name="vehicle_type">motorcycle</field>
        <field name="min_minutes">60</field>
        <field name="grace_minutes">10</field>
    </record>
    <record id="rate_daily_car" model="parking2.rate">
        <field name="name">Por Dia - Automovil</field>
        <field name="rate_type">daily</field>
        <field name="price">30.00</field>
        <field name="vehicle_type">car</field>
        <field name="min_minutes">60</field>
        <field name="grace_minutes">0</field>
    </record>
    <record id="rate_monthly_car" model="parking2.rate">
        <field name="name">Mensualidad - Automovil</field>
        <field name="rate_type">monthly</field>
        <field name="price">400.00</field>
        <field name="vehicle_type">car</field>
        <field name="min_minutes">0</field>
        <field name="grace_minutes">0</field>
    </record>
    <record id="rate_monthly_moto" model="parking2.rate">
        <field name="name">Mensualidad - Motocicleta</field>
        <field name="rate_type">monthly</field>
        <field name="price">250.00</field>
        <field name="vehicle_type">motorcycle</field>
        <field name="min_minutes">0</field>
        <field name="grace_minutes">0</field>
    </record>

    <record id="spot_a01" model="parking2.spot">
        <field name="name">A-01</field>
        <field name="floor">1</field>
        <field name="zone">A</field>
        <field name="spot_type">standard</field>
        <field name="state">available</field>
    </record>
    <record id="spot_a02" model="parking2.spot">
