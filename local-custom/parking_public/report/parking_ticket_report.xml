<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <record id="action_report_parking_ticket" model="ir.actions.report">
        <field name="name">Ticket de Parqueo</field>
        <field name="model">parking.ticket</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">parking_public.report_parking_ticket_document</field>
        <field name="report_file">parking_public.report_parking_ticket_document</field>
        <field name="print_report_name">'Ticket-' + (object.name or '')</field>
        <field name="binding_model_id" ref="model_parking_ticket"/>
        <field name="binding_type">report</field>
        <field name="paperformat_id" ref="base.paperformat_euro"/>
    </record>

</odoo>
