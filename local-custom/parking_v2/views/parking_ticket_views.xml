<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ═══ FORMULARIO PRINCIPAL DE TICKET ═══════════════════════════════════ -->
    <record id="view_parking_ticket_form" model="ir.ui.view">
        <field name="name">parking2.ticket.form</field>
        <field name="model">parking2.ticket</field>
        <field name="arch" type="xml">
            <form string="Ticket de Parqueo">
                <header>
                    <button name="action_checkout" type="object"
                            string="Registrar Salida" class="btn-primary"
                            invisible="state != 'open'"/>
                    <button name="action_print_ticket" type="object"
                            string="Imprimir Ticket"/>
                    <button name="action_cancel" type="object"
                            string="Anular"
                            invisible="state != 'open'"
                            confirm="Anular este ticket liberara el espacio. Continuar?"/>
                    <field name="state" widget="statusbar" statusbar_visible="open,done"/>
                </header>
                <sheet>

                    <!-- Alerta ticket cerrado -->
                    <div class="alert alert-warning" role="alert"
                         invisible="state != 'done'">
                        <strong>Ticket Cerrado.</strong>
                        No puede ser modificado. Cerrado por
                        <field name="cashier_exit_id" readonly="1" nolabel="1"/>
                        el <field name="exit_time" readonly="1" nolabel="1"/>.
                    </div>

                    <!-- Campos ocultos requeridos por modifiers -->
                    <field name="is_new_vehicle" invisible="1"/>

                    <div class="oe_title">
                        <label for="name" string="Numero de Ticket"/>
                        <h1><field name="name" readonly="1"/></h1>
                    </div>

                    <!-- ─── INGRESO DE PLACA ──────────────────────────────── -->
                    <group string="Registro de Vehiculo" invisible="state != 'open'">
                        <group>
                            <field name="input_plate"
                                   string="Placa del Vehiculo"
                                   placeholder="Escribe la placa y presiona Tab"
                                   readonly="vehicle_id != False"/>
                            <field name="vehicle_id" readonly="1"
                                   invisible="not vehicle_id"
                                   string="Vehiculo Encontrado"/>
                        </group>
                        <group invisible="not vehicle_id">
                            <field name="owner_name" readonly="1" string="Propietario"/>
                        </group>
                    </group>

                    <!-- ─── DATOS DEL CLIENTE NUEVO ──────────────────────── -->
                    <!-- Solo aparece si la placa no esta registrada          -->
                    <group string="Datos del Cliente Nuevo" invisible="not is_new_vehicle">
                        <div class="alert alert-info" role="alert">
                            <strong>Placa no registrada.</strong>
                            Llena los datos del cliente. Se guardaran automaticamente.
                        </div>
                        <group string="Propietario">
                            <field name="new_owner_name"
                                   required="is_new_vehicle"
                                   placeholder="Nombre completo del propietario"/>
                            <field name="new_owner_phone" placeholder="Telefono de contacto"/>
                            <field name="new_owner_id_number" placeholder="DPI o Cedula"/>
                        </group>
                        <group string="Vehiculo">
                            <field name="new_vehicle_type"/>
                            <field name="new_brand" placeholder="Ej: Toyota"/>
                            <field name="new_color" placeholder="Ej: Rojo"/>
                        </group>
                    </group>

                    <!-- ─── PARQUEO Y TARIFA ──────────────────────────────── -->
                    <group string="Datos del Parqueo">
                        <group>
                            <field name="spot_id"
                                   domain="[('state', 'in', ['available', 'reserved'])]"
                                   readonly="state != 'open'"/>
                            <field name="rate_id" readonly="state != 'open'"/>
                        </group>
                        <group>
                            <field name="entry_time" readonly="state != 'open'"/>
                            <field name="exit_time" readonly="1" invisible="state == 'open'"/>
                            <field name="duration_display" string="Tiempo en Parqueo" readonly="1"/>
                        </group>
                    </group>

                    <!-- ─── RESUMEN DE COBRO EN TIEMPO REAL ──────────────── -->
                    <!-- Muestra: tarifa, gracia, tiempo acumulado, total     -->
                    <div class="alert alert-primary" role="alert"
                         invisible="not rate_id">
                        <strong>Cobro: </strong>
                        <field name="tariff_info" readonly="1" nolabel="1"/>
                    </div>

                    <!-- ─── COBRO ─────────────────────────────────────────── -->
                    <group string="Cobro Final">
                        <group>
                            <field name="discount_applied" readonly="1"
                                   invisible="discount_applied == 0"
                                   string="Descuento Frecuente (%)"/>
                            <field name="amount_total" readonly="1"
                                   invisible="state == 'done'"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   string="Total Estimado"/>
                            <field name="amount_final" readonly="1"
                                   invisible="state != 'done'"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   string="Total Cobrado"/>
                            <field name="currency_id" invisible="1"/>
                        </group>
                        <group invisible="state == 'open'">
                            <field name="amount_paid" readonly="1"
                                   widget="monetary"
                                   options="{'currency_field': 'currency_id'}"
                                   string="Monto Recibido"/>
                        </group>
                    </group>

                    <group string="Registrado por">
                        <field name="user_id" readonly="1"/>
                        <field name="company_id" readonly="1"/>
                    </group>
                    <group string="Observaciones">
                        <field name="notes" nolabel="1"/>
                    </group>
                </sheet>
                <div class="oe_chatter">
                    <field name="message_follower_ids"/>
                    <field name="activity_ids"/>
                    <field name="message_ids"/>
                </div>
            </form>
        </field>
    </record>

    <!-- ═══ LISTA DE TICKETS ════════════════════════════════════════════════ -->
    <record id="view_parking_ticket_list" model="ir.ui.view">
        <field name="name">parking2.ticket.list</field>
        <field name="model">parking2.ticket</field>
        <field name="arch" type="xml">
            <tree string="Tickets de Parqueo"
                  decoration-success="state == 'open'"
                  decoration-danger="state == 'cancelled'">
                <field name="name" string="Ticket"/>
                <field name="plate" string="Placa"/>
                <field name="owner_name" string="Propietario"/>
                <field name="spot_id" string="Espacio"/>
                <field name="rate_id" string="Tarifa"/>
                <field name="entry_time" string="Entrada"/>
                <field name="exit_time" string="Salida"/>
                <field name="duration_display" string="Duracion"/>
                <field name="amount_total" string="Total"
                       widget="monetary" options="{'currency_field': 'currency_id'}"/>
                <field name="currency_id" column_invisible="1"/>
                <field name="state" string="Estado"/>
            </tree>
        </field>
    </record>

    <!-- ═══ KANBAN TICKETS ACTIVOS ══════════════════════════════════════════ -->
    <record id="view_parking_ticket_kanban" model="ir.ui.view">
        <field name="name">parking2.ticket.kanban</field>
        <field name="model">parking2.ticket</field>
        <field name="arch" type="xml">
            <kanban>
                <field name="name"/>
                <field name="plate"/>
                <field name="owner_name"/>
                <field name="spot_id"/>
                <field name="entry_time"/>
                <field name="duration_display"/>
                <field name="amount_total"/>
                <field name="state"/>
                <field name="currency_id"/>
                <templates>
                    <t t-name="kanban-box">
                        <div class="oe_kanban_card oe_kanban_global_click">
                            <div class="oe_kanban_content">
                                <div class="o_kanban_record_top">
                                    <strong class="o_kanban_record_title text-primary">
                                        <field name="name"/>
                                    </strong>
                                    <span t-attf-class="badge #{record.state.raw_value == 'open' ? 'text-bg-success' : 'text-bg-secondary'}">
                                        <field name="state"/>
                                    </span>
                                </div>
                                <div class="o_kanban_record_body mt8">
                                    <div><b>Placa:</b> <field name="plate"/> - <field name="owner_name"/></div>
                                    <div><b>Espacio:</b> <field name="spot_id"/></div>
                                    <div><b>Entrada:</b> <field name="entry_time" widget="datetime"/></div>
                                    <div><b>Tiempo:</b> <field name="duration_display"/></div>
                                    <div><b>Total:</b> <field name="amount_total" widget="monetary" options="{'currency_field': 'currency_id'}"/></div>
                                </div>
                                <div class="o_kanban_record_bottom mt4" t-if="record.state.raw_value == 'open'">
                                    <button name="action_checkout" type="object"
                                            class="btn btn-primary btn-sm w-100">
                                        Registrar Salida
                                    </button>
                                </div>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <!-- ═══ BUSQUEDA ════════════════════════════════════════════════════════ -->
    <record id="view_parking_ticket_search" model="ir.ui.view">
        <field name="name">parking2.ticket.search</field>
        <field name="model">parking2.ticket</field>
        <field name="arch" type="xml">
            <search string="Buscar Tickets">
                <field name="name" string="Ticket"/>
                <field name="plate" string="Placa"/>
                <field name="owner_name" string="Propietario"/>
                <field name="spot_id" string="Espacio"/>
                <separator/>
                <filter name="open" string="En Parqueo" domain="[('state','=','open')]"/>
                <filter name="done" string="Cerrados" domain="[('state','=','done')]"/>
                <filter name="cancelled" string="Anulados" domain="[('state','=','cancelled')]"/>
                <group expand="0" string="Agrupar Por">
                    <filter string="Estado" name="group_state" context="{'group_by': 'state'}"/>
                    <filter string="Espacio" name="group_spot" context="{'group_by': 'spot_id'}"/>
                    <filter string="Tarifa" name="group_rate" context="{'group_by': 'rate_id'}"/>
                    <filter string="Fecha" name="group_entry" context="{'group_by': 'entry_time:day'}"/>
                </group>
            </search>
        </field>
    </record>

    <!-- ═══ ACCIONES ════════════════════════════════════════════════════════ -->
    <record id="action_parking_ticket" model="ir.actions.act_window">
        <field name="name">Todos los Tickets</field>
        <field name="res_model">parking2.ticket</field>
        <field name="view_mode">tree,kanban,form</field>
        <field name="search_view_id" ref="view_parking_ticket_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">No hay tickets aun.</p>
        </field>
    </record>

    <record id="action_parking_ticket_active" model="ir.actions.act_window">
        <field name="name">Vehiculos en Parqueo</field>
        <field name="res_model">parking2.ticket</field>
        <field name="view_mode">kanban,tree,form</field>
        <field name="domain">[('state','=','open')]</field>
        <field name="search_view_id" ref="view_parking_ticket_search"/>
        <field name="help" type="html">
            <p class="o_view_nocontent_smiling_face">El parqueo esta vacio.</p>
        </field>
    </record>

    <!-- ═══ WIZARD DE SALIDA Y COBRO ════════════════════════════════════════ -->
    <record id="view_parking_checkout_wizard" model="ir.ui.view">
        <field name="name">parking2.checkout.wizard.form</field>
        <field name="model">parking2.checkout.wizard</field>
        <field name="arch" type="xml">
            <form string="Registrar Salida y Cobro">
                <sheet>
                    <div class="alert alert-info" role="alert">
                        Verifique el cobro e ingrese el monto recibido del cliente.
                    </div>

                    <group string="Resumen del Ticket">
                        <group>
                            <field name="ticket_id" readonly="1"/>
                            <field name="plate" readonly="1"/>
                            <field name="owner_name" readonly="1"/>
                            <field name="spot_name" readonly="1" string="Espacio"/>
                        </group>
                        <group>
                            <field name="rate_name" readonly="1" string="Tarifa"/>
                            <field name="entry_time" readonly="1"/>
                            <field name="duration_display" readonly="1" string="Tiempo"/>
                            <field name="discount_applied" readonly="1"
                                   invisible="discount_applied == 0"
                                   string="Descuento (%)"/>
                        </group>
                    </group>

                    <group string="Cobro">
                        <group>
                            <field name="amount_total" readonly="1"
                                   string="Total a Cobrar"/>
                            <field name="amount_paid"
                                   string="Monto Recibido del Cliente"/>
                        </group>
                        <group>
                            <field name="amount_change" readonly="1"
                                   string="Vuelto a Entregar"/>
                            <field name="discount_applied" readonly="1"
                                   invisible="discount_applied == 0"
                                   string="Descuento (%)"/>
                        </group>
                    </group>
                </sheet>
                <footer>
                    <button name="action_confirm_checkout" type="object"
                            string="Confirmar Cobro y Registrar Salida"
                            class="btn-primary"/>
                    <button string="Cancelar" special="cancel"/>
                </footer>
            </form>
        </field>
    </record>

</odoo>
